# Railway Environment Variables Template
# Copy this to Railway's Environment Variables section

# Gateway Port (Railway will auto-assign, but nanobot uses this internally)
PORT=18790

# Python settings
PYTHONUNBUFFERED=1

# Optional: Restrict nanobot workspace for security
# NANOBOT_RESTRICT_WORKSPACE=true

# Note: API keys and channel tokens should be set in config.json
# which will be mounted in the persistent volume at /root/.nanobot/
